{
  "name": "certprep",
  "version": "0.1.0",
  "private": true,
  "description": "Free certification practice tests and focused study resources.",
  "type": "module",
  "scripts": {
    "validate:data": "node scripts/run_validator.mjs",
    "validate:data:report": "node scripts/run_validator.mjs --write-report",
    "build:site": "eleventy",
    "build": "npm run validate:data && npm run build:site",
    "start": "eleventy --serve",
    "serve": "eleventy --serve"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6"
  }
}
